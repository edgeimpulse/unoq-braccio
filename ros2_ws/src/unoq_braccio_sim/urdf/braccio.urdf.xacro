<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="unoq_braccio">
  <xacro:property name="pi" value="3.14159265359"/>

  <link name="world"/>
  <link name="base_link">
    <visual>
      <geometry><cylinder radius="0.06" length="0.04"/></geometry>
      <material name="braccio_blue"><color rgba="0.05 0.18 0.8 1"/></material>
    </visual>
    <collision><geometry><cylinder radius="0.06" length="0.04"/></geometry></collision>
    <inertial><mass value="0.4"/><inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>

  <joint name="base_fixed" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <xacro:macro name="arm_link" params="name length radius color">
    <link name="${name}">
      <visual>
        <origin xyz="${length / 2} 0 0" rpy="0 ${pi / 2} 0"/>
        <geometry><cylinder radius="${radius}" length="${length}"/></geometry>
        <material name="${name}_mat"><color rgba="${color}"/></material>
      </visual>
      <collision>
        <origin xyz="${length / 2} 0 0" rpy="0 ${pi / 2} 0"/>
        <geometry><cylinder radius="${radius}" length="${length}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="${length / 2} 0 0"/>
        <mass value="0.15"/>
        <inertia ixx="0.0004" iyy="0.0004" izz="0.0004" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
  </xacro:macro>

  <xacro:arm_link name="shoulder_link" length="0.12" radius="0.018" color="0.94 0.6 0.05 1"/>
  <xacro:arm_link name="elbow_link" length="0.12" radius="0.016" color="0.08 0.45 0.85 1"/>
  <xacro:arm_link name="wrist_link" length="0.08" radius="0.014" color="0.92 0.92 0.92 1"/>
  <xacro:arm_link name="gripper_link" length="0.05" radius="0.01" color="0.15 0.15 0.15 1"/>

  <joint name="base" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.04"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="2" velocity="1"/>
  </joint>

  <joint name="shoulder" type="revolute">
    <parent link="shoulder_link"/>
    <child link="elbow_link"/>
    <origin xyz="0.12 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.309" upper="1.309" effort="2" velocity="1"/>
  </joint>

  <joint name="elbow" type="revolute">
    <parent link="elbow_link"/>
    <child link="wrist_link"/>
    <origin xyz="0.12 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="2" velocity="1"/>
  </joint>

  <joint name="wrist_vertical" type="revolute">
    <parent link="wrist_link"/>
    <child link="gripper_link"/>
    <origin xyz="0.08 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="1" velocity="1"/>
  </joint>
</robot>
