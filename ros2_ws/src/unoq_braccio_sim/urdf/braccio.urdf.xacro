<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="unoq_braccio">
  <xacro:arg name="controllers_file" default=""/>
  <xacro:arg name="mesh_dir" default=""/>

  <material name="braccio_orange"><color rgba="1.0 0.34 0.02 1"/></material>
  <material name="braccio_orange_dark"><color rgba="0.76 0.18 0.02 1"/></material>
  <material name="braccio_white"><color rgba="0.94 0.94 0.9 1"/></material>
  <material name="braccio_metal"><color rgba="0.72 0.72 0.68 1"/></material>
  <material name="braccio_black"><color rgba="0.03 0.035 0.045 1"/></material>
  <material name="camera_black"><color rgba="0.01 0.01 0.015 1"/></material>
  <material name="lens_blue"><color rgba="0.08 0.28 0.55 1"/></material>

  <xacro:macro name="box_inertial" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass * (y * y + z * z) / 12.0}"
        iyy="${mass * (x * x + z * z) / 12.0}"
        izz="${mass * (x * x + y * y) / 12.0}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="joint_hub_visual" params="x y z radius material">
    <visual>
      <origin xyz="${x} ${y} ${z}" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="${radius}" length="0.018"/></geometry>
      <material name="${material}"/>
    </visual>
  </xacro:macro>

  <xacro:macro name="servo_box_visual" params="x y z sx sy sz">
    <visual>
      <origin xyz="${x} ${y} ${z}"/>
      <geometry><box size="${sx} ${sy} ${sz}"/></geometry>
      <material name="braccio_black"/>
    </visual>
  </xacro:macro>

  <xacro:macro name="mesh_visual" params="filename material x y z rr rp ry">
    <visual>
      <origin xyz="${x} ${y} ${z}" rpy="${rr} ${rp} ${ry}"/>
      <geometry>
        <mesh filename="file://$(arg mesh_dir)/${filename}" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="${material}"/>
    </visual>
  </xacro:macro>

  <xacro:macro name="paired_arm_link" params="name length plate_height plate_thickness y_offset mesh mesh_x mesh_y mesh_z">
    <link name="${name}">
      <xacro:mesh_visual filename="${mesh}" material="braccio_orange" x="${mesh_x}" y="${mesh_y}" z="${mesh_z}" rr="0" rp="0" ry="0"/>
      <collision>
        <origin xyz="${length / 2.0} 0 0"/>
        <geometry><box size="${length} ${y_offset * 2.0 + plate_thickness} ${plate_height}"/></geometry>
      </collision>
      <xacro:box_inertial mass="0.18" x="${length}" y="${y_offset * 2.0 + plate_thickness}" z="${plate_height}"/>
    </link>
  </xacro:macro>

  <link name="world"/>

  <link name="base_link">
    <xacro:mesh_visual filename="braccio_base.stl" material="braccio_orange" x="0" y="0.004" z="0.04" rr="0" rp="0" ry="3.1416"/>
    <collision>
      <origin xyz="0 0 0.045"/>
      <geometry><cylinder radius="0.09" length="0.09"/></geometry>
    </collision>
    <inertial>
      <mass value="0.7"/>
      <inertia ixx="0.002" iyy="0.002" izz="0.002" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="base_fixed" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <xacro:paired_arm_link name="shoulder_link" length="0.14" plate_height="0.035" plate_thickness="0.012" y_offset="0.035" mesh="braccio_shoulder.stl" mesh_x="-0.0045" mesh_y="0.0055" mesh_z="-0.026"/>
  <xacro:paired_arm_link name="elbow_link" length="0.13" plate_height="0.03" plate_thickness="0.01" y_offset="0.03" mesh="braccio_elbow.stl" mesh_x="-0.0045" mesh_y="0.005" mesh_z="-0.025"/>
  <xacro:paired_arm_link name="wrist_link" length="0.075" plate_height="0.026" plate_thickness="0.01" y_offset="0.024" mesh="braccio_wrist_pitch.stl" mesh_x="0.003" mesh_y="-0.0004" mesh_z="-0.024"/>

  <link name="wrist_rotate_link">
    <xacro:mesh_visual filename="braccio_wrist_roll.stl" material="braccio_white" x="0.006" y="0" z="0" rr="0" rp="0" ry="0"/>
    <collision>
      <origin xyz="0.028 0 0"/>
      <geometry><box size="0.05 0.05 0.035"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.12" x="0.05" y="0.05" z="0.035"/>
  </link>

  <link name="gripper_carriage">
    <visual>
      <origin xyz="0.02 0 0"/>
      <geometry><box size="0.04 0.05 0.025"/></geometry>
      <material name="braccio_white"/>
    </visual>
    <visual>
      <origin xyz="0.01 0 0.022"/>
      <geometry><cylinder radius="0.019" length="0.018"/></geometry>
      <material name="braccio_metal"/>
    </visual>
    <collision>
      <origin xyz="0.02 0 0"/>
      <geometry><box size="0.04 0.05 0.025"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.1" x="0.04" y="0.05" z="0.025"/>
  </link>

  <link name="left_finger">
    <xacro:mesh_visual filename="braccio_left_gripper.stl" material="braccio_white" x="0" y="-0.012" z="0" rr="0" rp="1.5708" ry="0"/>
    <collision>
      <origin xyz="0.04 0.024 0"/>
      <geometry><box size="0.08 0.012 0.014"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.03" x="0.08" y="0.012" z="0.014"/>
  </link>

  <link name="right_finger">
    <xacro:mesh_visual filename="braccio_right_gripper.stl" material="braccio_white" x="0" y="-0.012" z="0.010" rr="0" rp="1.5708" ry="0"/>
    <collision>
      <origin xyz="0.04 -0.024 0"/>
      <geometry><box size="0.08 0.012 0.014"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.03" x="0.08" y="0.012" z="0.014"/>
  </link>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.034 0.026 0.022"/></geometry>
      <material name="camera_black"/>
    </visual>
    <visual>
      <origin xyz="0.018 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.008" length="0.006"/></geometry>
      <material name="lens_blue"/>
    </visual>
    <collision>
      <geometry><box size="0.034 0.026 0.022"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.04" x="0.034" y="0.026" z="0.022"/>
  </link>

  <joint name="base" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.11"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="2" velocity="1"/>
  </joint>

  <joint name="shoulder" type="revolute">
    <parent link="shoulder_link"/>
    <child link="elbow_link"/>
    <origin xyz="0.14 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.309" upper="1.309" effort="2" velocity="1"/>
  </joint>

  <joint name="elbow" type="revolute">
    <parent link="elbow_link"/>
    <child link="wrist_link"/>
    <origin xyz="0.13 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="2" velocity="1"/>
  </joint>

  <joint name="wrist_vertical" type="revolute">
    <parent link="wrist_link"/>
    <child link="wrist_rotate_link"/>
    <origin xyz="0.075 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="1" velocity="1"/>
  </joint>

  <joint name="wrist_rotation" type="revolute">
    <parent link="wrist_rotate_link"/>
    <child link="gripper_carriage"/>
    <origin xyz="0.045 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="1" velocity="1"/>
  </joint>

  <joint name="gripper" type="prismatic">
    <parent link="gripper_carriage"/>
    <child link="left_finger"/>
    <origin xyz="0.04 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0.035" effort="1" velocity="0.05"/>
  </joint>

  <joint name="right_finger_fixed" type="fixed">
    <parent link="gripper_carriage"/>
    <child link="right_finger"/>
    <origin xyz="0.04 0 0"/>
  </joint>

  <joint name="camera_mount" type="fixed">
    <parent link="gripper_carriage"/>
    <child link="camera_link"/>
    <origin xyz="0.052 0 0.04" rpy="0 0 0"/>
  </joint>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="base">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="shoulder">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="elbow">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist_vertical">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist_rotation">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="gripper">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(arg controllers_file)</parameters>
    </plugin>
  </gazebo>
</robot>
